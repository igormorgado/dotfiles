if [[ "{{ .chezmoi.os }}" == "linux" ]]; then
  # Load OS ID for distro detection
  if [[ -r /etc/os-release ]]; then
    source /etc/os-release
  fi

  if [[ "$ID" == "arch" ]]; then
    # Pacman on Arch Linux
    {{- if .packages.arch.pacman.cli }}
    sudo pacman -Sy --noconfirm {{ range .packages.arch.pacman.cli }} {{ . }}{{ end }}
    {{- end }}
    {{- if .packages.arch.pacman.gui }}
    if has_gui_session; then
      sudo pacman -Sy --noconfirm {{ range .packages.arch.pacman.gui }} {{ . }}{{ end }}
    fi
    {{- end }}
    install_uv_arch
    install_node_nvm_arch
  elif [[ "$ID" == "debian" ]]; then
    # APT on Debian (independent from Ubuntu)
    sudo apt-get update
    {{- if .packages.debian.apt.cli }}
    sudo apt-get install -y {{ range .packages.debian.apt.cli }} {{ . }}{{ end }}
    {{- end }}
    {{- if .packages.debian.apt.gui }}
    if has_gui_session; then
      sudo apt-get install -y {{ range .packages.debian.apt.gui }} {{ . }}{{ end }}
    fi
    {{- end }}
    install_uv_debian
    install_neovim_appimage_debian
    install_node_nvm_debian
  elif [[ "$ID" == "ubuntu" ]]; then
    # APT on Ubuntu (independent from Debian)
    sudo apt-get update
    {{- if .packages.ubuntu.apt.cli }}
    sudo apt-get install -y {{ range .packages.ubuntu.apt.cli }} {{ . }}{{ end }}
    {{- end }}
    {{- if .packages.ubuntu.apt.gui }}
    if has_gui_session; then
      sudo apt-get install -y {{ range .packages.ubuntu.apt.gui }} {{ . }}{{ end }}
    fi
    {{- end }}
    install_uv_ubuntu
    install_neovim_appimage_ubuntu
    install_node_nvm_ubuntu
  fi
elif [[ "{{ .chezmoi.os }}" == "darwin" ]]; then
  # Homebrew on macOS
  brew update
  brew install {{- if .packages.darwin.brew }}{{ range .packages.darwin.brew }} {{ . }}{{ end }}{{ end }}
  install_uv_darwin
fi

# Install npm packages globally if npm is available
if command -v npm >/dev/null 2>&1; then
  export npm_config_prefix="$HOME/.local"
  mkdir -p "$npm_config_prefix/bin" "$npm_config_prefix/lib"
  npm install -g {{- if .packages.npm.global }}{{ range .packages.npm.global }} {{ . }}{{ end }}{{ end }}
fi
