#!/usr/bin/env bash
set -e

export PATH="$HOME/.local/bin:$PATH"

has_gui_session() {
  [[ -n "${DISPLAY-}" || -n "${WAYLAND_DISPLAY-}" ]]
}

install_uv_arch() {
  if command -v uv >/dev/null 2>&1; then
    return 0
  fi

  if command -v curl >/dev/null 2>&1; then
    curl -LsSf "https://astral.sh/uv/install.sh" | sh
  elif command -v wget >/dev/null 2>&1; then
    wget -qO- "https://astral.sh/uv/install.sh" | sh
  else
    echo "Cannot install uv (missing curl/wget)" >&2
    return 1
  fi

  local uv_source="" uvx_source=""
  for uv_source in "$HOME/.local/bin/uv" "$HOME/.cargo/bin/uv"; do
    if [[ -x "$uv_source" ]]; then
      break
    fi
    uv_source=""
  done

  if [[ -z "$uv_source" ]]; then
    echo "uv install finished but uv was not found in expected locations" >&2
    return 1
  fi

  mkdir -p "$HOME/.local/bin"
  local uv_link="$HOME/.local/bin/uv"
  if [[ "$uv_source" != "$uv_link" ]]; then
    if [[ -L "$uv_link" ]]; then
      ln -sfn "$uv_source" "$uv_link"
    elif [[ -e "$uv_link" ]]; then
      echo "Not updating $uv_link (exists and is not a symlink)"
    else
      ln -s "$uv_source" "$uv_link"
    fi
  fi

  uvx_source="$(dirname "$uv_source")/uvx"
  local uvx_link="$HOME/.local/bin/uvx"
  if [[ -x "$uvx_source" ]] && [[ "$uvx_source" != "$uvx_link" ]]; then
    if [[ -L "$uvx_link" ]]; then
      ln -sfn "$uvx_source" "$uvx_link"
    elif [[ -e "$uvx_link" ]]; then
      echo "Not updating $uvx_link (exists and is not a symlink)"
    else
      ln -s "$uvx_source" "$uvx_link"
    fi
  fi
}

