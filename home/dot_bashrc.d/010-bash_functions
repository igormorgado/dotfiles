function jupstop() {
	local jdir="${HOME}/Drobbox/nb"
	local ldir="${jdir}/.log"
	local pidfile="${ldir}/jupyter.pid"

	if [ -r "${pidfile}" ]; then
		PID=$(cat "${pidfile}" )
		printf "Killing Jupyter at PID %d" "${PID}"
		kill "${PID}"
		sleep 2
		kill -9 "${PID}" 2> /dev/null || rm "${pidfile}"

	else
		printf "Could not find pid file or jupyter isn't running. Exiting"
		return 1
	fi

}

